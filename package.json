{
  "name": "lexgeocat-vue",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,scss}\"",
    "postinstall": "node scripts/copy-vendor-assets.mjs",
    "a11y:icons": "node scripts/add-aria-hidden.mjs"
  },
  "dependencies": {
    "@fontsource/dm-serif-display": "^5.1.0",
    "@fontsource/inter": "^5.1.1",
    "@fontsource/jetbrains-mono": "^5.1.2",
    "@fontsource/syne": "^5.1.1",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@unhead/vue": "^3.1.4",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "jiti": "^2.7.0",
    "prettier": "^3.0.0",
    "sass": "^1.101.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.12",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.2.8"
  }
}
